# Backend API Configuration
API_URL=http://localhost:8000/api

# AWS S3 Configuration (if direct upload is needed)
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=your-bucket-name

# API Keys (for future use)
# GOOGLE_API_KEY=your-google-api-key     # from aistudio.google.com/apikey (for image staging)
# NANOBANANA_API_KEY=your-api-key       # from nanobananaapi.ai/api-key (alternative)
# IMGBB_API_KEY=your-imgbb-key         # from imgbb.com (required only with NANOBANANA)
# WORLDLABS_API_KEY=your-api-key
